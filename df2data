from __future__ import annotations

from typing import Any

from lfx.custom.custom_component.component import Component
from lfx.inputs.inputs import HandleInput
from lfx.schema.data import Data
from lfx.template.field.base import Output


class AgentChatHistoryAdapter(Component):
    display_name = "Agent Chat History Adapter"
    description = "Converts Message History rows into Data list for Tool Calling Agent chat_history."
    name = "AgentChatHistoryAdapter"
    icon = "messages-square"

    inputs = [
        HandleInput(
            name="history",
            display_name="Message History Table",
            input_types=["Table", "DataFrame", "Data", "Message"],
            required=True,
        ),
    ]

    outputs = [
        Output(
            name="chat_history",
            display_name="Chat History",
            method="build_chat_history",
        )
    ]

    @staticmethod
    def _records_from_history(history: Any) -> list[dict[str, Any]]:
        if history is None:
            return []

        if isinstance(history, list):
            records: list[dict[str, Any]] = []
            for item in history:
                if isinstance(item, Data):
                    records.append(item.data)
                elif hasattr(item, "data"):
                    records.append(item.data)
                elif isinstance(item, dict):
                    records.append(item)
            return records

        if isinstance(history, Data):
            data = history.data
            if isinstance(data, list):
                return [item for item in data if isinstance(item, dict)]
            if isinstance(data, dict):
                return [data]

        if hasattr(history, "to_dict"):
            try:
                return history.to_dict(orient="records")
            except TypeError:
                raw = history.to_dict()
                if isinstance(raw, list):
                    return raw
                if isinstance(raw, dict):
                    return list(raw.values())

        if hasattr(history, "data"):
            data = history.data
            if isinstance(data, list):
                return [item for item in data if isinstance(item, dict)]
            if isinstance(data, dict):
                return [data]

        return []

    @staticmethod
    def _normalize_sender(sender: Any) -> str:
        value = str(sender or "").strip().lower()

        if value in {"user", "human", "person"}:
            return "User"

        return "Machine"

    def build_chat_history(self) -> list[Data]:
        records = self._records_from_history(self.history)

        chat_history: list[Data] = []

        for row in records:
            text = row.get("text") or row.get("message") or row.get("content")
            if not text:
                continue

            sender = row.get("sender") or row.get("sender_name") or row.get("role")

            chat_history.append(
                Data(
                    data={
                        "text": str(text),
                        "sender": self._normalize_sender(sender),
                    }
                )
            )

        self.status = {
            "messages": len(chat_history),
        }

        return chat_history
